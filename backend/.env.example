# Meta Assets Chain 主网扫链配置示例（本地端到端用 deploy-local 生成的 .env.local）
RPC_URL=https://rpc.ma-chain.xyz
POOL_ADDRESS=0x0000000000000000000000000000000000000000
NFT_ADDRESS=0x0000000000000000000000000000000000000000
DATABASE_URL=postgres://mapool:mapool@127.0.0.1:5433/mapool
# 从哪个高度起扫（部署高度）
START_BLOCK=0
# 单批区块数（区块高度区间 getLogs）
BATCH_SIZE=2000
# 追平后的轮询间隔
POLL_MS=1500
# 公链可设 >0 防 reorg
CONFIRMATIONS=0
PORT=8787
